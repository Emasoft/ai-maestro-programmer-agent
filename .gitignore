# Development directories
*_dev/
docs_dev/
scripts_dev/

# Agent / skill / tool reports (private data — paths, tokens, internal notes)
# Both /reports/ and /reports_dev/ MUST be gitignored per the global
# agent-reports-location rule. /reports_dev/ is already matched by *_dev/
# above; both are also listed explicitly so plugin validators that do not
# expand the *_dev/ glob still see the coverage.
/reports/
/reports_dev/

# Python
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment
.env
.env.*

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/

# Claude Code — ignore everything under .claude/ EXCEPT the PROJECT memory
# scope, which lives in-repo under .claude/project/memory/ and MUST be tracked
# + pushed (the shared, cross-dev wiki memory). Re-include each parent dir
# before the memory tree (order matters).
.claude/**
!.claude/project/
!.claude/project/memory/
!.claude/project/memory/**

# LLM Externalizer
llm_externalizer_output/

# TLDR
.tldr/
.tldrignore
.tldr_session_*

# SERENA MCP state (local project metadata, not published)
.serena/

# git-cliff scratch — ephemeral release notes between bump and push
.git-cliff-release-notes.md

# Added by CPV standardize
.coverage
