#!/usr/bin/env bash
# pre-push hook: enforces CPV validation (--strict) before any push.
#
# Uses the cpv-remote-validate launcher via uvx — no local CPV install needed.
# Environment-isolated: the target plugin's local configs can't interfere.
#
# Install: git config core.hooksPath .githooks
#
# NO BYPASS. Every push must pass CPV --strict. No exceptions.

set -euo pipefail

# NOTE: No bypass. Even publish.py goes through this gate.
# CPV validation ALWAYS runs before any push. No exceptions.

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  Pre-push: Running CPV validation (--strict)                ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Find the plugin root (directory containing .claude-plugin/plugin.json)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT=""

# Walk up from .githooks/ or .git/hooks/ to find plugin root
SEARCH_DIR="$SCRIPT_DIR"
for i in 1 2 3 4 5; do
    SEARCH_DIR="$(dirname "$SEARCH_DIR")"
    if [ -f "$SEARCH_DIR/.claude-plugin/plugin.json" ]; then
        PLUGIN_ROOT="$SEARCH_DIR"
        break
    fi
done

if [ -z "$PLUGIN_ROOT" ]; then
    echo "ERROR: Cannot find plugin root (.claude-plugin/plugin.json)"
    echo "       Searched up from: $SCRIPT_DIR"
    exit 1
fi

echo "Plugin root: $PLUGIN_ROOT"
echo ""

# Check uvx is available
if ! command -v uvx &> /dev/null; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  BLOCKED: uvx not found. Install uv first:                  ║"
    echo "║    curl -LsSf https://astral.sh/uv/install.sh | sh          ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

# Run CPV validation via remote launcher (--strict)
# uvx downloads CPV into an isolated env — no local dependency conflicts
if uvx --from "git+https://github.com/Emasoft/claude-plugins-validation" \
       --with pyyaml \
       cpv-remote-validate plugin "$PLUGIN_ROOT" --strict; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  CPV validation PASSED (--strict). Push allowed.            ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 0
else
    EXIT_CODE=$?
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  BLOCKED: CPV validation FAILED (--strict, exit=$EXIT_CODE)  ║"
    echo "║                                                              ║"
    echo "║  Fix the issues above, then retry:                           ║"
    echo "║    uv run python scripts/publish.py --patch                  ║"
    echo "║                                                              ║"
    echo "║  NO BYPASS. Every push must pass CPV --strict.               ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi
