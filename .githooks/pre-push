#!/usr/bin/env bash
# pre-push hook: strict publish enforcement.
# Auto-generated by scripts/publish.py. Do NOT edit by hand — every
# publish.py run rewrites this file from its inline template.
#
# Refuses `git push` unless AI_MAESTRO_PUBLISH_AUTHORIZED=1 is set in the
# environment. publish.py sets it immediately before calling `git push`,
# AFTER every validation step has passed with zero issues.

set -eu

if [ "${AI_MAESTRO_PUBLISH_AUTHORIZED:-}" != "1" ]; then
    printf '\n' >&2
    printf 'x git push REFUSED by pre-push hook.\n' >&2
    printf '\n' >&2
    printf '  Strict publish policy: every push to origin MUST go through\n' >&2
    printf '  scripts/publish.py so that lint, tests, and CPV --strict are\n' >&2
    printf '  re-verified immediately before the push. The hook is enforced\n' >&2
    printf '  via core.hooksPath = .githooks, installed by publish.py.\n' >&2
    printf '\n' >&2
    printf '  Run one of:\n' >&2
    printf '    uv run python scripts/publish.py --patch\n' >&2
    printf '    uv run python scripts/publish.py --minor\n' >&2
    printf '    uv run python scripts/publish.py --major\n' >&2
    printf '\n' >&2
    exit 1
fi

exit 0
