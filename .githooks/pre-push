#!/usr/bin/env bash
# pre-push hook: strict publish enforcement via PROCESS ANCESTRY.
# Auto-generated by scripts/publish.py. Do NOT edit by hand — every
# publish.py run rewrites this file from its inline template.
#
# Walks the hook's ancestor process tree looking for a python invocation
# of scripts/publish.py. If found, the push is allowed. Otherwise refused.
# This is intentionally NOT gated by an environment variable — env vars
# are trivially spoofed by `FOO=1 git push`. The process tree is not.

set -eu

# Walk up the process tree from the hook shell's PID, looking for a
# python / uv invocation of scripts/publish.py. Max depth 15 to guard
# against pathological loops.
find_publish_ancestor() {
    pid=$1
    depth=0
    while [ -n "${pid}" ] && [ "${pid}" != "0" ] && [ "${pid}" != "1" ] && [ "${depth}" -lt 15 ]; do
        cmd=$(ps -o command= -p "${pid}" 2>/dev/null || printf '')
        if [ -z "${cmd}" ]; then
            return 1
        fi
        # Match: <python interpreter> ... scripts/publish.py [args]
        # Accepts:   python scripts/publish.py
        #            python3 scripts/publish.py
        #            python3.12 scripts/publish.py
        #            /usr/bin/env python3 scripts/publish.py
        #            /abs/path/to/python scripts/publish.py
        # Rejects:   bash -c "touch scripts/publish.py && git push"
        #            git push
        #            any shell where publish.py is not the actual interpreter target
        case "${cmd}" in
            *python*scripts/publish.py*|*python*/scripts/publish.py*)
                return 0
                ;;
        esac
        ppid=$(ps -o ppid= -p "${pid}" 2>/dev/null | tr -d ' ' || printf '')
        if [ -z "${ppid}" ] || [ "${ppid}" = "${pid}" ]; then
            return 1
        fi
        pid="${ppid}"
        depth=$((depth + 1))
    done
    return 1
}

if ! find_publish_ancestor "$$"; then
    printf '\n' >&2
    printf 'x git push REFUSED by pre-push hook.\n' >&2
    printf '\n' >&2
    printf '  Strict publish policy: every push to origin MUST go through\n' >&2
    printf '  scripts/publish.py so that lint, tests, and CPV --strict are\n' >&2
    printf '  re-verified immediately before the push. The hook verifies\n' >&2
    printf '  its caller via PROCESS ANCESTRY — not an env var — so there\n' >&2
    printf '  is no trivial way around it.\n' >&2
    printf '\n' >&2
    printf '  Run one of:\n' >&2
    printf '    uv run python scripts/publish.py --patch\n' >&2
    printf '    uv run python scripts/publish.py --minor\n' >&2
    printf '    uv run python scripts/publish.py --major\n' >&2
    printf '\n' >&2
    exit 1
fi

exit 0
